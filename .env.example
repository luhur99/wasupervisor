NODE_ENV=production
PORT=3000
TZ=Asia/Jakarta

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=wa_supervisor
DB_USER=wa_supervisor_user
DB_PASSWORD=your_strong_password_here
DB_POOL_MAX=10

# Anthropic (Claude / openclaw agent)
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=2048

# CloudChat WhatsApp CRM
CLOUDCHAT_API_URL=https://app.cloudchat.id/api/public/v1/messages
CLOUDCHAT_API_KEY=your_cloudchat_bearer_token
CLOUDCHAT_SESSION_ID=SESSION_12345
CLOUDCHAT_WEBHOOK_SECRET=optional_hmac_secret

# Internal API key for PHP dashboard (store SHA-256 hash here)
# Generate: node -e "const crypto=require('crypto'); const k='your-raw-key'; console.log(crypto.createHash('sha256').update(k).digest('hex'));"
INTERNAL_API_KEY_HASH=sha256_hash_of_your_dashboard_api_key

# Supervisor WhatsApp number (receives daily summaries and problem alerts)
SUPERVISOR_PHONE=6281234567890

# File storage
UPLOAD_PATH=./uploads/responses
MAX_FILE_SIZE_MB=10
